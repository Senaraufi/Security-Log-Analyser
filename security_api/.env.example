# Groq AI API Configuration (FREE)
# Get your free API key from: https://console.groq.com

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# MySQL Database Configuration (Optional — leave unset to run without a database)
# Uncomment and set a real value only if you need persistent audit-trail storage.
# For docker-compose --profile db: DATABASE_URL=mysql://root:logr@db:3306/security_LogsDB
# For local MySQL:                 DATABASE_URL=mysql://root:yourpassword@localhost:3306/security_LogsDB
#DATABASE_URL=
